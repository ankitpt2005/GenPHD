NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
# Use Supabase's current browser key. The legacy NEXT_PUBLIC_SUPABASE_ANON_KEY is also supported for existing setups.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Public Turnstile widget key. Configure the matching private key in Supabase Auth > Bot and Abuse Protection.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-cloudflare-turnstile-site-key
# Demo access is deliberately disabled by default. Set true only for local, non-production exploration.
GENPHD_ALLOW_DEMO_MODE=false
# Optional: required only for trusted, server-only administration tasks. Never expose this value to the browser.
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-sol
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto-beta
OPENROUTER_COST_QUALITY_TRADEOFF=6
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Comma-separated provider priority. The next provider is used if the previous one fails validation or is unavailable.
GENPHD_DECISION_PROVIDERS=openrouter,groq,openai
SOURCE_FETCH_ALLOWLIST=developers.openai.com,langchain-ai.github.io
